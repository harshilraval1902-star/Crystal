# Server Environment Variables
# Copy this file to .env and fill in your values

# ── Database ────────────────────────────────────────────
# MySQL (for production/cPanel):
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/crystal_water"

# SQLite (for local development — change provider in schema.prisma too):
# DATABASE_URL="file:./dev.db"

# ── JWT Secrets ─────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET="your-super-secret-access-key-change-this"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# ── Server ───────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS ────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS="http://localhost:4173,http://localhost:5173"

# ── Uploads ──────────────────────────────────────────────
UPLOAD_DIR="uploads"
MAX_FILE_SIZE_MB=5
