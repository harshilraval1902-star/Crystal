# Backend Environment Variables Template
# Copy this file to .env and fill in the values for production

# Prisma Database URL
DATABASE_URL="mysql://username:password@localhost:3306/database_name"

# JWT Secrets (Generate strong random strings for these in production)
JWT_ACCESS_SECRET="generate-a-strong-secret-key-for-access"
JWT_REFRESH_SECRET="generate-a-strong-secret-key-for-refresh"

# JWT Expirations
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# Server Port
PORT=3001

# Environment (must be 'production' in live server)
NODE_ENV=production

# CORS Allowed Origins (Comma separated, NO WILDCARDS ALLOWED)
ALLOWED_ORIGINS="https://yourdomain.com,https://www.yourdomain.com"

# Uploads Configuration
UPLOAD_DIR="uploads"
MAX_FILE_SIZE_MB=5
